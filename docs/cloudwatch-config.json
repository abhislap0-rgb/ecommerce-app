{
  "metrics": {
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_user"],
        "metrics_collection_interval": 60
      },
      "mem": {
        "measurement": ["mem_used_percent"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["disk_used_percent"],
        "metrics_collection_interval": 60,
        "resources": ["/"]
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/nginx/access.log",
            "log_group_name": "/ecommerce/nginx/access",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/nginx/error.log",
            "log_group_name": "/ecommerce/nginx/error",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/auth.log",
            "log_group_name": "/ecommerce/auth",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/ecommerce/security.log",
            "log_group_name": "/ecommerce/security",
            "log_stream_name": "{instance_id}"
          },
          {
            "file_path": "/var/log/ecommerce/app.log",
            "log_group_name": "/ecommerce/app",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}
